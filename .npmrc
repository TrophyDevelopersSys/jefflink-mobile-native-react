# Use hoisted node_modules so Metro (React Native bundler) can resolve
# transitive dependencies without following symlinks.
node-linker=hoisted

# Short virtual store path — prevents Windows MAX_PATH (260) errors when
# Gradle writes build intermediates inside .pnpm package directories.
# Default would be node_modules/.pnpm which creates 293-char paths.
virtual-store-dir=C:\pvs
