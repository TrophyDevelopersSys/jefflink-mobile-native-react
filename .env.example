# JeffLink Monorepo — Environment Variables

# ===================================
# apps/web — Next.js Web Application
# ===================================
# Copy to apps/web/.env.local
NEXT_PUBLIC_API_BASE_URL=https://jefflink.onrender.com/api/v1

# ===================================
# apps/mobile — Expo Mobile App
# ===================================
# Copy to apps/mobile/.env or use EAS secrets
EXPO_PUBLIC_API_BASE_URL=https://jefflink.onrender.com/api/v1
EXPO_PUBLIC_DEV_FORCE_HOME=0
