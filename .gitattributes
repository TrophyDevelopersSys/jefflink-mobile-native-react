# Normalize line endings for all text files on checkout
* text=auto

# Force LF for source files
*.ts   text eol=lf
*.tsx  text eol=lf
*.js   text eol=lf
*.jsx  text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.css  text eol=lf
*.html text eol=lf
*.yaml text eol=lf
*.yml  text eol=lf

# Never touch binary files
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.svg  binary
*.ttf  binary
*.woff binary
*.woff2 binary

# Ignore node_modules line endings entirely
node_modules/** -text
