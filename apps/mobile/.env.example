# JeffLink Mobile — Environment Variables Reference
# Copy this file to .env and fill in values.
# EXPO_PUBLIC_* vars are embedded at build time (visible in the app bundle — never put secrets here).

# Production API (Render → api.jefflinkcars.com)
EXPO_PUBLIC_API_BASE_URL=https://api.jefflinkcars.com/api/v1

# Set to "1" to skip auth and force the home screen (dev only)
EXPO_PUBLIC_DEV_FORCE_HOME=0

# Local dev overrides:
#   Android emulator → EXPO_PUBLIC_API_BASE_URL=http://10.0.2.2:3000/api/v1
#   iOS simulator    → EXPO_PUBLIC_API_BASE_URL=http://localhost:3000/api/v1
#   Physical device  → EXPO_PUBLIC_API_BASE_URL=http://<your-lan-ip>:3000/api/v1
