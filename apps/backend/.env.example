# ─── Database ────────────────────────────────────────────────────────────────
# Neon PostgreSQL connection string (copy from Neon console → Connection details)
DATABASE_URL=postgresql://user:password@ep-xxx-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=replace-with-a-long-random-refresh-secret
JWT_REFRESH_EXPIRES_IN=7d

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of origins allowed to access the API
CORS_ORIGINS=http://localhost:8081,exp://localhost:8081
WEB_APP_URL=http://localhost:3000

# Auth debug options (set AUTH_EXPOSE_RESET_TOKEN=true only in non-production)
AUTH_EXPOSE_RESET_TOKEN=false

# ─── Mail / Password Reset ──────────────────────────────────────────────────
# Brevo SMTP relay:
# - Leave SMTP_URL empty unless you have a full smtp://... connection string
# - For port 587 use SMTP_SECURE=false (STARTTLS). Use true only with port 465.
SMTP_URL=
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-brevo-smtp-login
SMTP_PASS=your-brevo-smtp-key
# Optional Brevo aliases supported by the backend if you prefer explicit names:
SMTP_BREVO_LOGIN=your-brevo-smtp-login
SMTP_BREVO_API_KEY=your-brevo-smtp-key

MAIL_FROM=no-reply@jefflinkcars.com
MAIL_FROM_NAME=JeffLink
MAIL_REPLY_TO=support@jefflinkcars.com

# ─── Rate limiting ───────────────────────────────────────────────────────────
THROTTLE_TTL=60000
THROTTLE_LIMIT=120

# ─── Cloudflare R2 (primary media storage) ─────────────────────────────────
# Bucket: jefflink-storage
# CDN: cdn.jefflinkcars.com -> CNAME -> pub-<id>.r2.dev
#
# Bucket folder structure:
# cms/sliders/ - hero and homepage slider images
# cms/banners/ - promotional banner images
# cms/pages/ - static page images
# cars/<carId>/ - car listing photos
# houses/<propertyId>/ - house listing photos
# land/<propertyId>/ - land listing photos
# vendors/<vendorId>/ - vendor branding assets
# users/avatars/<userId>/ - user avatar images
# documents/ - contracts and KYC docs (private bucket recommended)
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET=jefflink-storage
R2_PUBLIC_URL=https://cdn.jefflinkcars.com

# ─── Redis (BullMQ queues) ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Search (optional) ───────────────────────────────────────────────────────
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=your-meilisearch-master-key

# ─── MongoDB Atlas ───────────────────────────────────────────────────────────
# Connection string (SRV format recommended for Atlas)
MONGO_URI=
MONGO_DB_NAME=jefflink
MONGO_APP_NAME=jefflink-api

# Feature flags — keep false until Atlas collections are seeded
CMS_ATLAS_ENABLED=false
GPS_ATLAS_ENABLED=false
DOCUMENTS_ATLAS_ENABLED=false

# ─── Monitoring (optional) ───────────────────────────────────────────────────
SENTRY_DSN=
